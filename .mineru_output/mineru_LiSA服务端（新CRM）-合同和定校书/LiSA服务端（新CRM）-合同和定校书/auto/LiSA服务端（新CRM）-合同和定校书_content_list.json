        "type": "text",
        "text": "一、LiSA服务端 （新CRM）：合同启动分配",
        "text_level": 1,
        "page_idx": 3
    },
    {
        "type": "text",
        "text": "操作说明：",
        "text_level": 1,
        "page_idx": 3
    },
    {
        "type": "text",
        "text": "3、点击“启动合同分配” 按钮，如下图；",
        "text_level": 1,
        "page_idx": 3
    },
    {
        "type": "image",
        "img_path": "images/7d84e267fefcf08fc83e690a007cb0214b0e0901cd7a340a4d9b45bf141dc3c6.jpg",
        "img_caption": [],
        "img_footnote": [],
